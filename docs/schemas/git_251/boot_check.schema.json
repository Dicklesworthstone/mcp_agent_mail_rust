{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mcp-agent-mail/git_251/boot_check.schema.json",
  "title": "archive boot check event",
  "description": "Structured tracing payload for boot-time archive integrity checks.",
  "type": "object",
  "additionalProperties": false,
  "required": ["ts", "level", "target", "name", "fields"],
  "x-event-names": [
    "boot_check_started",
    "boot_check_finding",
    "boot_check_completed",
    "boot_check_aborted",
    "boot_check_auto_repair_attempted",
    "boot_check_auto_repair_failed",
    "boot_check_auto_repair_gate_violated"
  ],
  "x-planned": true,
  "x-drift-required-fields": [],
  "properties": {
    "ts": { "type": "string" },
    "level": { "type": "string", "enum": ["trace", "debug", "info", "warn", "error"] },
    "target": { "type": "string" },
    "name": { "type": "string" },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_slug", "caller", "args_hash", "duration_ms", "outcome", "git_version", "mode"],
      "properties": {
        "repo_slug": { "type": "string" },
        "caller": { "type": "string" },
        "args_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "duration_ms": { "type": "number", "minimum": 0 },
        "outcome": { "type": "string", "enum": ["success", "retrying", "succeeded_after_retry", "exhausted", "error"] },
        "git_version": { "type": "string" },
        "mode": { "type": "string", "enum": ["warn", "abort", "auto_repair"] },
        "root": { "type": "string" },
        "total_projects": { "type": "integer", "minimum": 0 },
        "project": { "type": "string" },
        "kind": { "type": "string" },
        "detail": { "type": "string" },
        "findings_count": { "type": "integer", "minimum": 0 },
        "auto_repaired_count": { "type": "integer", "minimum": 0 },
        "degraded": { "type": "boolean" },
        "actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "before_state": { "type": "object" },
        "after_state": { "type": "object" },
        "error": { "type": "string" }
      }
    }
  }
}
