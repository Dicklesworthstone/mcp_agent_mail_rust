{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mcp-agent-mail/git_251/run_git_locked.schema.json",
  "title": "run_git_locked event",
  "description": "Structured tracing payload for wrapped git shell-outs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["ts", "level", "target", "name", "fields"],
  "x-event-names": [
    "git_binary_unresolvable",
    "git_binary_revalidating",
    "git_binary_version_drift",
    "git_binary_revalidation_failed_keeping_previous",
    "resolved_git_binary",
    "git_binary_known_bad",
    "known_bad_embedded_parse_failed",
    "known_bad_user_override",
    "known_bad_user_parse_failed",
    "known_bad_user_file_unreadable",
    "known_bad_catalog_loaded",
    "flock_acquire_failed",
    "git_segfault_retry_succeeded",
    "git_segfault_retry_attempt",
    "git_segfault_retry_exhausted",
    "git_spawn_failed",
    "git_locked_exit_ok",
    "git_locked_exit_segfault_like",
    "git_locked_exit_signal",
    "git_locked_exit_timeout",
    "git_locked_exit_io_error"
  ],
  "x-drift-required-fields": [],
  "properties": {
    "ts": { "type": "string" },
    "level": { "type": "string", "enum": ["trace", "debug", "info", "warn", "error"] },
    "target": { "type": "string", "enum": ["mcp_agent_mail::git_locked", "mcp_agent_mail::git_binary"] },
    "name": { "type": "string" },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_slug", "caller", "args_hash", "duration_ms", "outcome", "git_version"],
      "properties": {
        "repo_slug": { "type": "string" },
        "caller": { "type": "string" },
        "args_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "duration_ms": { "type": "number", "minimum": 0 },
        "outcome": { "type": "string", "enum": ["success", "retrying", "succeeded_after_retry", "exhausted", "error"] },
        "git_version": { "type": "string" },
        "repo": { "type": "string" },
        "err": { "type": "string" },
        "binary": { "type": "string" },
        "attempt": { "type": "integer", "minimum": 0 },
        "attempt_n": { "type": "integer", "minimum": 0 },
        "signal": { "type": "integer" },
        "binary_version": { "type": "string" },
        "after_secs": { "type": "integer", "minimum": 0 },
        "path": { "type": "string" },
        "age_secs": { "type": "integer", "minimum": 0 },
        "old_version": { "type": "string" },
        "new_version": { "type": "string" },
        "cached_path": { "type": "string" },
        "cached_version": { "type": "string" },
        "version": { "type": "string" },
        "source": { "type": "string" },
        "validation_step": { "type": "integer", "minimum": 0 },
        "remediation": { "type": "string" },
        "code": { "type": "string" },
        "entries": { "type": "integer", "minimum": 0 },
        "error": { "type": "string" }
      }
    }
  }
}
